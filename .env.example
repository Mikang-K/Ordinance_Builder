GOOGLE_API_KEY=your-gemini-api-key-here
MAX_INTERVIEW_TURNS=5
LOG_LEVEL=INFO

# 디버그 엔드포인트 활성화 여부 (프로덕션: false / 로컬 개발: true)
DEBUG_MODE=false

# Neo4j connection
# Local Docker: bolt://localhost:7687
# Neo4j AuraDB: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-auradb-password

# PostgreSQL (LangGraph 체크포인터 + 세션 레지스트리)
# docker-compose는 POSTGRES_PASSWORD로 컨테이너와 backend URL을 자동 구성함
POSTGRES_PASSWORD=your-local-postgres-password
POSTGRES_URL=postgresql://app_user:your-local-postgres-password@localhost:5432/ordinance_builder

# National Law Information Center Open API
LAW_API_KEY=your-law-api-key-here

# Firebase 서버 사이드 (백엔드 인증 검증용 서비스 계정 JSON 경로)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Firebase Web App (프론트엔드 클라이언트 — Firebase 콘솔 > 프로젝트 설정 > 웹 앱 > SDK 구성)
# 로컬 개발: vite.config.ts의 envDir: '../' 설정으로 이 파일에서 자동 로드
# Docker 빌드: docker-compose.yml의 build.args 경유로 Dockerfile ARG에 주입
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
